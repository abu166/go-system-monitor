{
  "id": null,
  "uid": "system-monitor-overview",
  "title": "System Monitor Overview",
  "tags": [
    "system-monitor"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Usage %",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "system_monitor_cpu_usage_percent",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage %",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "system_monitor_memory_usage_percent",
          "legendFormat": "Memory",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Usage %",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "system_monitor_disk_usage_percent",
          "legendFormat": "Disk",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Collection Errors (rate)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "rate(system_monitor_collection_errors_total[5m])",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests (rate)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "rate(system_monitor_http_requests_total[5m])",
          "legendFormat": "{{method}} {{path}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Active Alerts (firing)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (alertname, severity) (ALERTS{alertstate=\"firing\"})",
          "legendFormat": "{{alertname}} ({{severity}})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API p95 Latency (s)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(system_monitor_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Availability Ratio (5m)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 24
      },
      "targets": [
        {
          "expr": "1 - (sum(rate(system_monitor_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(system_monitor_http_requests_total[5m])), 0.001))",
          "legendFormat": "availability",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Budget Burn (99.9% SLO)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 24
      },
      "targets": [
        {
          "expr": "(sum(rate(system_monitor_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(system_monitor_http_requests_total[5m])), 0.001)) / 0.001",
          "legendFormat": "burn rate",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Alert History (24h)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "sum by (alertname) (max_over_time(ALERTS{alertstate=\"firing\"}[24h]))",
          "legendFormat": "{{alertname}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Top Failing Endpoints (5xx rate)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "targets": [
        {
          "expr": "topk(5, sum by (path) (rate(system_monitor_http_requests_total{status=~\"5..\"}[5m])))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  }
}

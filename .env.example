# Backend server configuration
BACKEND_PORT=8080
BACKEND_HISTORY_LIMIT=100
BACKEND_HISTORY_MAX_AGE=24h
BACKEND_HISTORY_MAX_FILE_SIZE_BYTES=10485760
BACKEND_HISTORY_IN_MEMORY_ONLY=false
BACKEND_HISTORY_FALLBACK_TO_MEMORY=true
BACKEND_READ_TIMEOUT=5s
BACKEND_READ_HEADER_TIMEOUT=2s
BACKEND_WRITE_TIMEOUT=5s
BACKEND_IDLE_TIMEOUT=30s
BACKEND_MAX_HEADER_BYTES=1048576
BACKEND_SHUTDOWN_TIMEOUT=10s
BACKEND_DISK_PATH=/
BACKEND_STREAM_INTERVAL=3s
BACKEND_HISTORY_FILE=/app/data/metrics-history.jsonl
BACKEND_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost
BACKEND_LOG_SAMPLE_RATE=5
BACKEND_CPU_ALERT_THRESHOLD=85
BACKEND_MEMORY_ALERT_THRESHOLD=85
BACKEND_DISK_ALERT_THRESHOLD=90

# Frontend host port
FRONTEND_PORT=3000
VITE_STREAM_RECONNECT_BASE_MS=1000
VITE_STREAM_RECONNECT_MAX_MS=30000

# Observability stack
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
